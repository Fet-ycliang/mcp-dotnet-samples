    "abbrs": "[variables('$fxv#0')]",
    "normalizedStem": "[toLower(parameters('resourceNameStem'))]",
    "apimName": "[if(not(empty(parameters('apimNameOverride'))), parameters('apimNameOverride'), format('{0}{1}', variables('abbrs').apiManagementService, variables('normalizedStem')))]",
    "effectiveDnsRg": "[if(empty(parameters('privateDnsZoneResourceGroupName')), resourceGroup().name, parameters('privateDnsZoneResourceGroupName'))]",
    "dnsLinkName": "[format('link-{0}', take(uniqueString(variables('apimName'), parameters('virtualNetworkResourceId')), 16))]",
    "apimPrivateDnsZoneNames": [
      "azure-api.net",
      "portal.azure-api.net",
      "developer.azure-api.net",
      "management.azure-api.net",
      "scm.azure-api.net"
    ],
    "deleteApimScript": "set -e\r\necho \"Deleting APIM: ${APIM_NAME} in RG: ${RESOURCE_GROUP}\"\r\nif az apim show --name \"${APIM_NAME}\" --resource-group \"${RESOURCE_GROUP}\" &>/dev/null; then\r\n  az apim delete --name \"${APIM_NAME}\" --resource-group \"${RESOURCE_GROUP}\" --yes\r\n  echo \"APIM deleted.\"\r\nelse\r\n  echo \"APIM ${APIM_NAME} not found – skipping.\"\r\nfi\r\n",
    "deleteDnsLinksScript": "[if(and(parameters('removeApimPrivateDnsLinks'), not(empty(parameters('virtualNetworkResourceId')))), 'echo \"Removing APIM private DNS zone VNet links from zones: ${DNS_ZONES}\"\r\nfor ZONE in ${DNS_ZONES}; do\r\n  if az network private-dns link vnet show \\\r\n      --resource-group \"${DNS_RG}\" \\\r\n      --zone-name \"${ZONE}\" \\\r\n      --name \"${LINK_NAME}\" &>/dev/null; then\r\n    az network private-dns link vnet delete \\\r\n      --resource-group \"${DNS_RG}\" \\\r\n      --zone-name \"${ZONE}\" \\\r\n      --name \"${LINK_NAME}\" \\\r\n      --yes\r\n    echo \"Removed VNet link from ${ZONE}\"\r\n  else\r\n    echo \"Link ${LINK_NAME} not found in ${ZONE} – skipping.\"\r\n  fi\r\ndone\r\n', '')]",
    "fullScript": "[format('{0}{1}', variables('deleteApimScript'), variables('deleteDnsLinksScript'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deploymentScripts",
      "apiVersion": "2023-08-01",
      "name": "[format('remove-apim-{0}', take(uniqueString(variables('apimName'), resourceGroup().id), 8))]",
      "location": "[parameters('location')]",
      "kind": "AzureCLI",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', parameters('userAssignedIdentityResourceId'))]": {}
        }
      },
      "properties": {
        "azCliVersion": "2.63.0",
        "retentionInterval": "PT1H",
        "cleanupPreference": "OnSuccess",
        "environmentVariables": "[concat(createArray(createObject('name', 'APIM_NAME', 'value', variables('apimName')), createObject('name', 'RESOURCE_GROUP', 'value', resourceGroup().name)), if(and(parameters('removeApimPrivateDnsLinks'), not(empty(parameters('virtualNetworkResourceId')))), createArray(createObject('name', 'DNS_RG', 'value', variables('effectiveDnsRg')), createObject('name', 'DNS_ZONES', 'value', join(variables('apimPrivateDnsZoneNames'), ' ')), createObject('name', 'LINK_NAME', 'value', variables('dnsLinkName'))), createArray()))]",
        "scriptContent": "[variables('fullScript')]"
      }
    }
  ],
  "outputs": {
    "deletedApimName": {
      "type": "string",
      "value": "[variables('apimName')]"
    },
    "scriptProvisioningState": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deploymentScripts', format('remove-apim-{0}', take(uniqueString(variables('apimName'), resourceGroup().id), 8))), '2023-08-01').provisioningState]"
    }
