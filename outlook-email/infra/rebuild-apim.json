    {
      "condition": "[and(parameters('deployApimPrivateDns'), not(empty(parameters('virtualNetworkResourceId'))))]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "[format('rebuild-apim-dns-{0}', take(uniqueString(variables('apiManagementName'), resourceGroup().id), 8))]",
      "resourceGroup": "[variables('effectiveDnsRg')]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "apiManagementName": {
            "value": "[variables('apiManagementName')]"
          },
          "privateIpAddress": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', format('rebuild-apim-{0}', take(uniqueString(variables('apiManagementName'), resourceGroup().id), 8))), '2025-04-01').outputs.privateIpAddress.value]"
          },
          "virtualNetworkResourceId": {
            "value": "[parameters('virtualNetworkResourceId')]"
          },
          "existingVirtualNetworkLinkName": {
            "value": "[parameters('existingVirtualNetworkLinkName')]"
          },
          "tags": {
            "value": "[parameters('tags')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.39.26.7824",
              "templateHash": "15382745633763128476"
            }
          },
          "parameters": {
            "apiManagementName": {
              "type": "string",
              "metadata": {
                "description": "The API Management service name used in the default internal hostnames."
              }
            },
            "privateIpAddress": {
              "type": "string",
              "metadata": {
                "description": "The internal private IP address of the APIM instance."
              }
            },
            "virtualNetworkResourceId": {
              "type": "string",
              "metadata": {
                "description": "The virtual network resource ID that should resolve the APIM private hostnames."
              }
            },
            "tags": {
              "type": "object",
              "defaultValue": {},
              "metadata": {
                "description": "Tags applied to the private DNS resources."
              }
            },
            "existingVirtualNetworkLinkName": {
              "type": "string",
              "defaultValue": "",
              "metadata": {
                "description": "Optional existing private DNS virtual network link name to adopt when the shared zones are already linked to the target VNet."
              }
            }
          },
          "variables": {
            "zoneNames": [
              "azure-api.net",
              "portal.azure-api.net",
              "developer.azure-api.net",
              "management.azure-api.net",
              "scm.azure-api.net"
            ],
            "linkName": "[if(not(empty(parameters('existingVirtualNetworkLinkName'))), parameters('existingVirtualNetworkLinkName'), format('link-{0}', take(uniqueString(parameters('apiManagementName'), parameters('virtualNetworkResourceId')), 16)))]"
          },
          "resources": [
            {
              "copy": {
                "name": "privateDnsZones",
                "count": "[length(variables('zoneNames'))]"
              },
              "type": "Microsoft.Network/privateDnsZones",
              "apiVersion": "2020-06-01",
              "name": "[variables('zoneNames')[copyIndex()]]",
              "location": "global",
              "tags": "[parameters('tags')]"
            },
            {
              "copy": {
                "name": "privateDnsZoneLinks",
                "count": "[length(variables('zoneNames'))]"
              },
              "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
              "apiVersion": "2020-06-01",
              "name": "[format('{0}/{1}', variables('zoneNames')[copyIndex()], variables('linkName'))]",
              "location": "global",
              "tags": "[parameters('tags')]",
              "properties": {
                "registrationEnabled": false,
                "virtualNetwork": {
                  "id": "[parameters('virtualNetworkResourceId')]"
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.Network/privateDnsZones', variables('zoneNames')[copyIndex()])]"
              ]
            },
            {
              "copy": {
                "name": "apimHostRecords",
                "count": "[length(variables('zoneNames'))]"
              },
              "type": "Microsoft.Network/privateDnsZones/A",
              "apiVersion": "2020-06-01",
              "name": "[format('{0}/{1}', variables('zoneNames')[copyIndex()], parameters('apiManagementName'))]",
              "properties": {
                "ttl": 3600,
                "aRecords": [
                  {
                    "ipv4Address": "[parameters('privateIpAddress')]"
                  }
                ]
              },
              "dependsOn": [
                "[resourceId('Microsoft.Network/privateDnsZones', variables('zoneNames')[copyIndex()])]"
              ]
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', format('rebuild-apim-{0}', take(uniqueString(variables('apiManagementName'), resourceGroup().id), 8)))]"
      ]
    }
  ],
  "outputs": {
    "apimName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', format('rebuild-apim-{0}', take(uniqueString(variables('apiManagementName'), resourceGroup().id), 8))), '2025-04-01').outputs.name.value]"
    },
    "apimGatewayUrl": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', format('rebuild-apim-{0}', take(uniqueString(variables('apiManagementName'), resourceGroup().id), 8))), '2025-04-01').outputs.gatewayUrl.value]"
    },
    "apimPrivateIpAddress": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', format('rebuild-apim-{0}', take(uniqueString(variables('apiManagementName'), resourceGroup().id), 8))), '2025-04-01').outputs.privateIpAddress.value]"
    }
  }
