            "name": {
              "type": "string",
              "value": "[parameters('apiManagementName')]"
            },
            "gatewayUrl": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.ApiManagement/service', parameters('apiManagementName')), '2024-06-01-preview').gatewayUrl]"
            },
            "privateIpAddress": {
              "type": "string",
              "value": "[if(empty(reference(resourceId('Microsoft.ApiManagement/service', parameters('apiManagementName')), '2024-06-01-preview').privateIPAddresses), '', reference(resourceId('Microsoft.ApiManagement/service', parameters('apiManagementName')), '2024-06-01-preview').privateIPAddresses[0])]"
            }
          }
        }
      }
