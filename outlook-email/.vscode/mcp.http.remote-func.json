{
  "inputs": [
    {
      "type": "promptString",
      "id": "funcapp-server-fqdn",
      "description": "Azure Functions FQDN"
    },
    {
      "type": "promptString",
      "id": "funcapp-access-token",
      "description": "Function App MCP OAuth access token",
      "password": true
    }
  ],
  "servers": {
    "outlook-email": {
      "type": "http",
      "url": "https://${input:funcapp-server-fqdn}/mcp",
      "headers": {
        "Authorization": "Bearer ${input:funcapp-access-token}"
      }
    }
  }
}
